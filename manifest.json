{
  "manifest_version": 3,
  "name": "Net Assets Scraper",
  "version": "2.0.0",
  "description": "Brand asset extraction tool — grab logos, images, videos, fonts, and colors from any website into an organized brand kit.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "19": "assets/icons/icon19.png",
    "32": "assets/icons/icon32.png",
    "38": "assets/icons/icon38.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "downloads",
    "clipboardWrite",
    "sidePanel",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "panel/panel.html"
  },
  "side_panel": {
    "default_path": "panel/panel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
